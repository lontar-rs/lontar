# Rust
/target/
*/target/
**/*.rs.bk
Cargo.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test outputs - ignore generated files in output directory
tests/fixtures/output/

# Ignore binary document outputs globally (common practice for Rust projects)
*.docx
*.pptx
*.xlsx
*.pdf
*.odt
*.odp
*.ods

# Explicitly allow reference documents for testing
!tests/fixtures/reference_docs/**/*.docx
!tests/fixtures/reference_docs/**/*.pptx
!tests/fixtures/reference_docs/**/*.xlsx
!tests/fixtures/reference_docs/**/*.pdf

# Python (for reference doc generation tools)
__pycache__/
*.pyc
.venv/
venv/

# LaTeX
*.aux
*.log
*.out
*.synctex.gz

# Coverage
lcov.info
coverage/
